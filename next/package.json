    "react-dom": "19.1.0",
    "next": "15.5.20"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "@eslint/eslintrc": "^3",
    "node-fetch": "^2.7.0"
  }
}
